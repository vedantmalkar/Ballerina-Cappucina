<launch>
    <group ns="detect_ball">
        <node name="detect_ball" pkg="ball_tracker" type="detect_ball_ros1.py" output="screen">
            <param name="tuning_mode" value="false" />
            <param name="h_min" value="100" />
            <param name="h_max" value="140" />
            <param name="s_min" value="50" />
            <param name="s_max" value="255" />
            <param name="v_min" value="50" />
            <param name="v_max" value="255" />
            <param name="x_min" value="10" />
            <param name="x_max" value="90" />
            <param name="y_min" value="20" />
            <param name="y_max" value="80" />
            <param name="sz_min" value="1" />
            <param name="sz_max" value="30" />
            <remap from="/image_in" to="/camera/image_raw" />
        </node>
    </group>

    <node name="move_bot" pkg="ball_tracker" type="move_bot_ros1.py" output="screen" />
</launch>